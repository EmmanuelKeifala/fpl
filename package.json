{
  "name": "fpl-agent",
  "version": "1.0.0",
  "description": "AI-powered Fantasy Premier League assistant with game theory optimization",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "auto": "tsx src/scheduler/runner.ts",
    "backtest:prepare": "tsx src/backtest/index.ts prepare-data",
    "backtest:run": "tsx src/backtest/index.ts run-season",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "tsx --test src/**/*.test.ts"
  },
  "keywords": [
    "fpl",
    "fantasy-premier-league",
    "ai-agent",
    "openai"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@openai/agents": "^0.4.4",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "sql.js": "^1.14.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/sql.js": "^1.4.9",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
